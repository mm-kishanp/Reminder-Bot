{
  "name": "teams-reminder-bot",
  "version": "1.0.0",
  "description": "Microsoft Teams reminder bot with recurring schedules, Graph calendar nudges, and proactive messaging.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "test": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "deploy": "echo Deploy via GitHub Actions workflow",
    "start:ngrok": "pwsh ./scripts/start-local-with-ngrok.ps1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@azure/cosmos": "^4.3.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "adaptivecards-templating": "^2.3.1",
    "axios": "^1.9.0",
    "botbuilder": "^4.23.3",
    "chrono-node": "^2.9.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "luxon": "^3.6.1",
    "@azure/msal-node": "^3.8.0",
    "rrule": "^2.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.15.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.1",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
